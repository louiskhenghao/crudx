{
  "name": "skills",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/skills/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": [
          "libs/skills/src/**/*.{ts,tsx,js,jsx}",
          "libs/skills/scripts/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/libs/skills"],
      "options": {
        "commands": [
          "rm -rf dist/libs/skills",
          "mkdir -p dist/libs/skills",
          "node libs/skills/scripts/build.js"
        ],
        "parallel": false
      }
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "commitMessageFormat": "chore(${projectName}): release ${version}",
        "tagPrefix": "${projectName}@",
        "trackDeps": true,
        "postTargets": ["skills:build"]
      }
    }
  }
}
