{
  "name": "rest-tanstack-adapter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/rest-tanstack-adapter/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "lint": {
      "executor": "@nx/linter:eslint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["libs/rest-tanstack-adapter/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/rest-tanstack-adapter",
        "tsConfig": "libs/rest-tanstack-adapter/tsconfig.lib.json",
        "project": "libs/rest-tanstack-adapter/package.json",
        "entryFile": "libs/rest-tanstack-adapter/src/index.ts",
        "format": ["cjs", "esm"],
        "external": [
          "@crudx/core",
          "@tanstack/react-query",
          "react",
          "react-dom"
        ],
        "rollupConfig": "@nx/react/plugins/bundle-rollup",
        "compiler": "babel",
        "assets": [
          {
            "glob": "libs/rest-tanstack-adapter/README.md",
            "input": ".",
            "output": "."
          }
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/rest-tanstack-adapter/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "version": {
      "executor": "@jscutlery/semver:version",
      "options": {
        "preset": "conventional",
        "commitMessageFormat": "chore(${projectName}): release ${version}",
        "tagPrefix": "${projectName}@",
        "trackDeps": true,
        "postTargets": ["rest-tanstack-adapter:build"]
      }
    }
  }
}
